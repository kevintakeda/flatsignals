{
  "name": "flatsignals",
  "version": "0.10.1",
  "description": "FlatSignals is an extremely fast reactivity library (~0.6kb)",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/react.mjs",
      "types": "./dist/react.d.ts"
    }
  },
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "bench": "vitest bench",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "size": "size-limit"
  },
  "license": "MIT",
  "devDependencies": {
    "@angular/core": "^22.0.4",
    "@biomejs/biome": "2.5.1",
    "@maverick-js/signals": "^6.0.0",
    "@preact/signals-core": "^1.14.3",
    "@reactively/core": "^0.0.8",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@solidjs/signals": "^0.13.13",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/reactivity": "^3.5.39",
    "alien-signals": "^3.2.1",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "size-limit": "^12.1.0",
    "solid-js": "^1.9.13",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "react": "^19.2.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "size-limit": [
    {
      "path": "dist/index.mjs",
      "limit": "0.68 kB"
    }
  ],
  "dependencies": {
    "vite": "^8.1.2"
  }
}
